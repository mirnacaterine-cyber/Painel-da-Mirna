{
  "name": "painel-da-mirna",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Painel pessoal da Mirna com agenda, banco de dados, arquivos, notícias e briefing diário.",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "check": "node scripts/check.mjs",
    "test": "node --test tests/*.test.mjs",
    "test:browser": "node scripts/browser-smoke.mjs",
    "validate": "npm run check && npm test",
    "validate:full": "npm run validate && npm run test:browser"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/blob": "^2.6.1"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
